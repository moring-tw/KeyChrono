<Window x:Class="CountdownApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="多重倒數計時器設定 (Windows 10/11)" Height="500" Width="680">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="1. 倒數時間(秒):" Width="130" VerticalAlignment="Center"/>
            <TextBox x:Name="TimeInput" Width="100" Text="10" VerticalContentAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="2. 圖片路徑:" Width="130" VerticalAlignment="Center"/>
            <TextBox x:Name="ImageInput" Width="250" Margin="0,0,10,0" VerticalContentAlignment="Center"/>
            <Button Content="瀏覽..." Width="60" Click="BrowseImage_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="3. 畫面顯示座標:" Width="130" VerticalAlignment="Center"/>
            <TextBlock Text="X:" VerticalAlignment="Center"/>
            <TextBox x:Name="XInput" Width="60" Margin="5,0,15,0" Text="0" VerticalContentAlignment="Center"/>
            <TextBlock Text="Y:" VerticalAlignment="Center"/>
            <TextBox x:Name="YInput" Width="60" Margin="5,0,0,0" Text="0" VerticalContentAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="4. 快捷鍵:" Width="130" VerticalAlignment="Center"/>
            <TextBox x:Name="HotkeyInput" Width="150" Margin="0,0,10,0" VerticalContentAlignment="Center"/>
            <TextBlock Text="(例如: F5, Ctrl+A)" Foreground="Gray" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="5. 圖片尺寸(寬x高):" Width="130" VerticalAlignment="Center"/>
            <TextBox x:Name="WidthInput" Width="60" Margin="5,0,5,0" Text="200" VerticalContentAlignment="Center"/>
            <TextBlock Text="x" VerticalAlignment="Center"/>
            <TextBox x:Name="HeightInput" Width="60" Margin="5,0,0,0" Text="200" VerticalContentAlignment="Center"/>
            <TextBlock Text="(像素)" Foreground="Gray" Margin="10,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="6. 自動重新計時:" Width="130" VerticalAlignment="Center"/>
            <CheckBox x:Name="AutoRestartCheck" Content="倒數完畢後自動重啟" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 修改了按鈕區域，新增刪除按鈕 -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,15,0,10">
            <Button Content="新增 / 更新計時器" Width="130" Margin="130,0,15,0" Click="AddTimer_Click" Padding="5"/>
            <Button Content="刪除選取的計時器" Width="130" Click="DeleteTimer_Click" Padding="5" Foreground="DarkRed"/>
        </StackPanel>

        <!-- 新增 SelectionMode 與 SelectionChanged 事件 -->
        <DataGrid Grid.Row="7" x:Name="TimerList" AutoGenerateColumns="False" IsReadOnly="True" 
                  HeadersVisibility="Column" SelectionMode="Single" SelectionChanged="TimerList_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="快捷鍵" Binding="{Binding HotkeyStr}" Width="65"/>
                <DataGridTextColumn Header="時間(秒)" Binding="{Binding Duration}" Width="65"/>
                <DataGridTextColumn Header="X, Y" Binding="{Binding Coordinates}" Width="65"/>
                <DataGridTextColumn Header="尺寸" Binding="{Binding Dimensions}" Width="75"/>
                <DataGridCheckBoxColumn Header="自動重計" Binding="{Binding AutoRestart}" Width="65"/>
                <DataGridTextColumn Header="圖片路徑" Binding="{Binding ImagePath}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>