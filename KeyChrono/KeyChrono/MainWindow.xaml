<Window x:Class="KeyChrono.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KeyChrono - 多重倒數計時器" Height="680" Width="780">

    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="#F0F0F0" Padding="3">
            <MenuItem Header="工具 (_T)">
                <MenuItem Header="ElevenLabs 語音生成 (TTS)..." Click="OpenTTSWindow_Click"/>
            </MenuItem>
        </Menu>

        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- 0: 基本設定標題 -->
                <RowDefinition Height="Auto"/>
                <!-- 1: 名稱 -->
                <RowDefinition Height="Auto"/>
                <!-- 2: 時間 -->
                <RowDefinition Height="Auto"/>
                <!-- 3: 圖片 -->
                <RowDefinition Height="Auto"/>
                <!-- 4: 快捷鍵 -->
                <RowDefinition Height="Auto"/>
                <!-- 5: 進階設定 (Expander) -->
                <RowDefinition Height="Auto"/>
                <!-- 6: 警示設定 (Expander) -->
                <RowDefinition Height="Auto"/>
                <!-- 7: 按鈕區 -->
                <RowDefinition Height="*"/>
                <!-- 8: DataGrid -->
            </Grid.RowDefinitions>

            <!-- 基本設定區 -->
            <TextBlock Grid.Row="0" Text="▼ 基本設定" FontWeight="Bold" Foreground="#333" FontSize="14" Margin="0,0,0,10"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,5,0,5">
                <TextBlock Text="計時器名稱:" Width="120" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBox x:Name="NameInput" Width="150" VerticalContentAlignment="Center"/>
                <TextBlock Text="(作為唯一識別碼)" Foreground="Gray" VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="10,5,0,5">
                <TextBlock Text="倒數時間(秒):" Width="120" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBox x:Name="TimeInput" Width="100" Text="10" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="10,5,0,5">
                <TextBlock Text="圖片路徑:" Width="120" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBox x:Name="ImageInput" Width="250" Margin="0,0,10,0" VerticalContentAlignment="Center"/>
                <Button Content="瀏覽..." Width="60" Click="BrowseImage_Click"/>
            </StackPanel>

            <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="10,5,0,15">
                <TextBlock Text="快捷鍵:" Width="120" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBox x:Name="HotkeyInput" Width="150" Margin="0,0,10,0" VerticalContentAlignment="Center"/>
                <TextBlock Text="(多個計時器可共用相同快捷鍵)" Foreground="Gray" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 進階設定區 -->
            <Expander Grid.Row="5" Header="進階設定 (展開 / 收合)" IsExpanded="False" FontWeight="Bold" Margin="0,0,0,10" BorderBrush="LightGray" BorderThickness="1" Padding="5">
                <StackPanel Margin="10,10,0,5">
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="畫面顯示座標:" Width="120" VerticalAlignment="Center"/>
                        <TextBlock Text="X:" VerticalAlignment="Center"/>
                        <TextBox x:Name="XInput" Width="50" Margin="5,0,15,0" VerticalContentAlignment="Center"/>
                        <TextBlock Text="Y:" VerticalAlignment="Center"/>
                        <TextBox x:Name="YInput" Width="50" Margin="5,0,0,0" VerticalContentAlignment="Center"/>
                        <TextBlock Text="(預設已為您計算螢幕正中央)" Foreground="Gray" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="畫面顯示尺寸:" Width="120" VerticalAlignment="Center"/>
                        <TextBlock Text="圖寬:" VerticalAlignment="Center"/>
                        <TextBox x:Name="WidthInput" Width="45" Margin="5,0,5,0" Text="200" VerticalContentAlignment="Center"/>
                        <TextBlock Text="圖高:" VerticalAlignment="Center"/>
                        <TextBox x:Name="HeightInput" Width="45" Margin="5,0,15,0" Text="200" VerticalContentAlignment="Center"/>
                        <TextBlock Text="字體大小:" VerticalAlignment="Center" FontWeight="Bold" Foreground="DarkBlue"/>
                        <TextBox x:Name="FontSizeInput" Width="45" Margin="5,0,0,0" Text="72" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="自動重新計時:" Width="120" VerticalAlignment="Center"/>
                        <CheckBox x:Name="AutoRestartCheck" Content="倒數完畢後自動重啟" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="執行中按快捷鍵:" Width="120" VerticalAlignment="Center" Foreground="DarkRed" FontWeight="Bold"/>
                        <RadioButton x:Name="ActionRestart" Content="重新計時" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <RadioButton x:Name="ActionStop" Content="停止 (顯示STOP)" IsChecked="True" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <RadioButton x:Name="ActionPause" Content="暫停 (保留時間)" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Expander>

            <!-- 警示設定區 (新增) -->
            <Expander Grid.Row="6" Header="警示設定 (展開 / 收合)" IsExpanded="False" FontWeight="Bold" Margin="0,0,0,15" BorderBrush="LightGray" BorderThickness="1" Padding="5">
                <StackPanel Margin="10,10,0,5">
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="剩餘多少時間開始閃爍(秒):" Width="170" VerticalAlignment="Center"/>
                        <TextBox x:Name="BlinkTimeInput" Width="50" Text="10" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="設定音效路徑:" Width="170" VerticalAlignment="Center"/>
                        <TextBox x:Name="AudioPathInput" Width="200" Margin="0,0,10,0" VerticalContentAlignment="Center"/>
                        <Button Content="瀏覽..." Width="60" Click="BrowseAudio_Click"/>
                        <TextBlock Text="(未填寫則不播放)" Foreground="Gray" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="剩餘多少時間播放音效(秒):" Width="170" VerticalAlignment="Center"/>
                        <TextBox x:Name="AudioTimeInput" Width="50" Text="10" VerticalContentAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Expander>

            <!-- 按鈕區 -->
            <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="新增 / 更新計時器" Width="130" Margin="10,0,15,0" Click="AddTimer_Click" Padding="5" Background="#2196F3" Foreground="White" FontWeight="Bold"/>
                <Button Content="刪除選取的計時器" Width="130" Click="DeleteTimer_Click" Padding="5" Foreground="DarkRed"/>
            </StackPanel>

            <!-- 資料表 (維持原欄位，警示設定不放入) -->
            <DataGrid Grid.Row="8" x:Name="TimerList" AutoGenerateColumns="False" IsReadOnly="True" 
                      HeadersVisibility="Column" SelectionMode="Single" SelectionChanged="TimerList_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="名稱" Binding="{Binding Name}" Width="80"/>
                    <DataGridTextColumn Header="快捷鍵" Binding="{Binding HotkeyStr}" Width="65"/>
                    <DataGridTextColumn Header="觸發行為" Binding="{Binding RetriggerActionText}" Width="65"/>
                    <DataGridTextColumn Header="時間" Binding="{Binding Duration}" Width="45"/>
                    <DataGridTextColumn Header="座標 (X, Y)" Binding="{Binding Coordinates}" Width="75"/>
                    <DataGridTextColumn Header="尺寸" Binding="{Binding Dimensions}" Width="65"/>
                    <DataGridTextColumn Header="字體" Binding="{Binding FontSize}" Width="45"/>
                    <DataGridCheckBoxColumn Header="重計" Binding="{Binding AutoRestart}" Width="45"/>
                    <DataGridTextColumn Header="圖片路徑" Binding="{Binding ImagePath}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </DockPanel>
</Window>