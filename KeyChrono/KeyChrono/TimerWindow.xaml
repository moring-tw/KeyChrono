<Window x:Class="CountdownApp.TimerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" SizeToContent="WidthAndHeight"
        ResizeMode="NoResize" WindowStartupLocation="Manual">
    <Grid>
        <!-- 更改 Stretch="Fill" 讓圖片可以依據指定的寬高自動縮放 -->
        <Image x:Name="BgImage" Stretch="Fill" />

        <TextBlock x:Name="TimeText" Foreground="Red" FontSize="72" FontWeight="Bold"
                   HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock.Effect>
                <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="2" />
            </TextBlock.Effect>
        </TextBlock>
    </Grid>
</Window>