<Window x:Class="KeyChrono.ElevenLabsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ElevenLabs 語音生成工具" Height="450" Width="500" WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- API Key 輸入區 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="ElevenLabs API Key:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="ApiKeyInput" Height="25" VerticalContentAlignment="Center" Padding="5,0"/>
        </StackPanel>

        <!-- 文字輸入區 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="要生成的文字內容 (支援中文):" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="TextInput" AcceptsReturn="True" TextWrapping="Wrap" 
                     VerticalScrollBarVisibility="Auto" Height="150" Padding="5"/>
        </StackPanel>

        <!-- 儲存路徑區 -->
        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="儲存音檔路徑 (*.mp3):" FontWeight="Bold" Margin="0,0,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="SavePathInput" Height="25" VerticalContentAlignment="Center" Margin="0,0,10,0" Padding="5,0"/>
                <Button Grid.Column="1" Content="瀏覽..." Click="BrowseSavePath_Click" Height="25"/>
            </Grid>
        </StackPanel>

        <!-- 執行按鈕 -->
        <Button Grid.Row="3" x:Name="GenerateButton" Content="生成語音 (Generate)" Height="40" 
                FontWeight="Bold" Background="#4CAF50" Foreground="White" FontSize="14" Click="Generate_Click"/>

        <!-- 狀態顯示 -->
        <TextBlock Grid.Row="4" x:Name="StatusText" Margin="0,10,0,0" Foreground="Gray" TextWrapping="Wrap" FontWeight="SemiBold"/>
    </Grid>
</Window>